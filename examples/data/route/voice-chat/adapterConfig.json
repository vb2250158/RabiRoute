{
  "enabled": true,
  "pipelinePreset": "voice_chat",
  "pipeline": {
    "id": "voice_chat",
    "inputAdapter": "fennenote",
    "outputAdapter": "fennenote",
    "outputPipeline": "fennenote",
    "promptOutputMode": "voice_short",
    "ttsProvider": "oumuq",
    "ttsVoice": "cloud_zh_voice",
    "ttsWorkerUrl": "http://127.0.0.1:8793/api/fennenote/playback",
    "ttsPlay": true,
    "preventFeedbackLoop": true,
    "replyToSource": false
  },
  "messageAdapters": [
    "fennenote"
  ],
  "messageAdapterPolicies": {
    "fennenote": {
      "inputEnabled": true,
      "outputEnabled": true,
      "supportedOutputs": [
        "text",
        "image",
        "voice",
        "file"
      ]
    }
  },
  "gatewayPort": 8791,
  "webhookPort": 8791,
  "webhookPath": "/webhook",
  "fenneNoteWebhookPort": 8791,
  "fenneNoteWebhookPath": "/fennenote",
  "codexThreadName": "RabiRoute Voice Chat",
  "codexCwd": "C:/Path/To/Your/Project",
  "agentRoleFile": "persona.md",
  "agentAdapters": [
    "codex"
  ],
  "dataDir": "./data/route/voice-chat",
  "configName": "voice-chat",
  "agentRoleId": "Rabi",
  "rolesDir": "./data/roles"
}
