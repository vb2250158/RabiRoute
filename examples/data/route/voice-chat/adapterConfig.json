{
  "enabled": false,
  "pipelinePreset": "voice_chat",
  "pipeline": {
    "id": "voice_chat",
    "inputAdapter": "speech",
    "outputAdapter": "tts",
    "outputPipeline": "rabispeech",
    "promptOutputMode": "voice_short",
    "ttsProvider": "local-tts",
    "ttsVoice": "Rabi",
    "ttsWorkerUrl": "http://127.0.0.1:8781/v1/audio/speech",
    "ttsPlay": true,
    "preventFeedbackLoop": true,
    "replyToSource": false
  },
  "messageAdapters": [
    "speech"
  ],
  "messageAdapterPolicies": {
    "speech": {
      "inputEnabled": true,
      "outputEnabled": true,
      "supportedOutputs": [
        "text",
        "image",
        "voice",
        "file"
      ]
    }
  },
  "gatewayPort": 8792,
  "webhookPort": 8792,
  "webhookPath": "/webhook",
  "routeVariables": {
    "speechAsrModel": "faster-whisper/small",
    "speechTtsModel": "local-tts/gpt-sovits",
    "speechVoice": "Rabi",
    "speechLanguage": "zh",
    "speechSpeed": "1",
    "speechThreshold": "0.02",
    "speechTranscribeThreshold": "0.025",
    "speechAdaptiveThreshold": "true",
    "speechSilenceMs": "900",
    "speechMinUtteranceMs": "350",
    "speechMaxUtteranceMs": "30000",
    "speechPreRollMs": "500",
    "speechInputGain": "1",
    "speechAutoSubmit": "true",
    "speechAutoPlay": "true"
  },
  "codexThreadName": "RabiRoute Voice Chat",
  "codexCwd": ".",
  "agentRoleFile": "persona.md",
  "agentAdapters": [
    "codex"
  ],
  "dataDir": "./data/route/voice-chat",
  "configName": "voice-chat",
  "agentRoleId": "Rabi",
  "rolesDir": "./data/roles"
}
