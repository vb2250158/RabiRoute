{
  "openapi": "3.0.1",
  "info": {
    "title": "RabiLinkMessage",
    "version": "1.0.0",
    "description": "RabiLinkMessage 用于把用户在 Rokid 智能体中说出的内容转发到 RabiLink Relay。手机端 RabiLink 会把任务继续交给电脑上的 RabiRoute 和 Codex 处理，并把回复返回给眼镜智能体。"
  },
  "servers": [
    {
      "url": "https://rabi.example.com"
    }
  ],
  "paths": {
    "/rokid/rabilink/tasks": {
      "post": {
        "operationId": "submitRabiLinkTask",
        "summary": "提交 RabiLink 任务",
        "description": "把用户原话提交到 RabiLink Relay，并立即返回新的 taskId。每次用户新输入都会创建新 taskId；后续用 getRabiLinkTaskMessages 按该 taskId 拉取消息列表，直到 shouldContinue=false。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "用户原始说话内容，或需要通过 RabiLink 转交给 Codex 的请求。"
                  },
                  "sender": {
                    "type": "string",
                    "description": "可选发送者显示名称，例如 Rokid user。"
                  },
                  "context": {
                    "type": "string",
                    "description": "可选简短上下文，帮助 RabiLink 理解消息来源和对话场景。"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功返回 JSON。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": "0 表示成功，非 0 表示失败。"
                    },
                    "ok": {
                      "type": "boolean",
                      "description": "接口是否成功。"
                    },
                    "status": {
                      "type": "string",
                      "description": "任务状态。"
                    },
                    "taskId": {
                      "type": "string",
                      "description": "任务 ID，后续轮询时使用。"
                    },
                    "text": {
                      "type": "string",
                      "description": "智能体可以转述给用户的文本。"
                    },
                    "answer": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "reply": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "content": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rokid/rabilink/tasks/{taskId}/messages": {
      "get": {
        "operationId": "getRabiLinkTaskMessages",
        "summary": "拉取指定 RabiLink 任务消息列表",
        "description": "按 submitRabiLinkTask 返回的 taskId 拉取该任务下的新增回复列表。每次处理 messages 后保存 nextCursor，下次作为 after 传入；直到 messages 为空且 shouldContinue=false 才结束本轮。",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "description": "submitRabiLinkTask 返回的任务 ID。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after",
            "in": "query",
            "required": false,
            "description": "已经读过的该任务内最后一条消息 ID。第一次拉取留空，后续使用上一次返回的 nextCursor。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回该任务下的新增消息列表。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": "0 表示成功，非 0 表示失败。"
                    },
                    "ok": {
                      "type": "boolean",
                      "description": "接口是否成功。"
                    },
                    "status": {
                      "type": "string",
                      "description": "任务消息流状态。messages/done/failed/streaming。"
                    },
                    "taskId": {
                      "type": "string",
                      "description": "submitRabiLinkTask 返回的任务 ID。"
                    },
                    "done": {
                      "type": "boolean",
                      "description": "手机桥是否已调用 finish 结束该任务。"
                    },
                    "shouldContinue": {
                      "type": "boolean",
                      "description": "是否继续调用本接口。true 表示任务未结束，或本次仍返回了需要处理的 messages；false 表示该 taskId 的消息已拉空且任务已结束。"
                    },
                    "nextCursor": {
                      "type": "string",
                      "description": "下一次轮询时传入 after。"
                    },
                    "text": {
                      "type": "string",
                      "description": "本次 messages 合并后的文本。"
                    },
                    "answer": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "reply": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "content": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "messages": {
                      "type": "array",
                      "description": "该 taskId 下 after 之后的新消息列表。智能体应逐条转述，处理完后保存 nextCursor。",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "任务内消息游标 ID。"
                          },
                          "seq": {
                            "type": "integer",
                            "description": "任务内消息序号。"
                          },
                          "createdAt": {
                            "type": "integer",
                            "description": "创建时间戳。"
                          },
                          "text": {
                            "type": "string",
                            "description": "要转述给用户的一条消息。"
                          },
                          "final": {
                            "type": "boolean",
                            "description": "是否为最后一条消息。"
                          }
                        }
                      }
                    },
                    "error": {
                      "type": "string",
                      "description": "失败原因。"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rokid/rabilink/tasks/{taskId}": {
      "get": {
        "operationId": "getRabiLinkTaskResult",
        "summary": "查询 RabiLink 任务状态",
        "description": "查询指定 RabiLink 任务状态。主要用于调试；眼镜端回复拉取应使用 getRabiLinkTaskMessages，不要把本接口的 text/reply/answer 当成用户回复重复播报。",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "description": "submitRabiLinkTask 返回的任务 ID。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回 JSON。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": "0 表示成功，非 0 表示失败。"
                    },
                    "ok": {
                      "type": "boolean",
                      "description": "接口是否成功。"
                    },
                    "status": {
                      "type": "string",
                      "description": "任务状态。"
                    },
                    "taskId": {
                      "type": "string",
                      "description": "任务 ID，后续轮询时使用。"
                    },
                    "text": {
                      "type": "string",
                      "description": "智能体可以转述给用户的文本。"
                    },
                    "answer": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "reply": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    },
                    "content": {
                      "type": "string",
                      "description": "与 text 相同，用于兼容平台。"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "RabiLinkToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RabiLink-Token",
        "description": "RabiLink Relay 访问令牌。导入插件后在授权配置中填写实际 token。"
      }
    }
  },
  "security": [
    {
      "RabiLinkToken": []
    }
  ]
}
