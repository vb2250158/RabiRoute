# NapCat HTTP API 地址
NAPCAT_HTTP_URL=http://127.0.0.1:3000
NAPCAT_ACCESS_TOKEN=

# Gateway WebSocket 端口（NapCat 连接此端口接收消息）
GATEWAY_PORT=8789

# QClaw Gateway API 配置
QCLAW_GATEWAY_URL=http://127.0.0.1:10978
QCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
QCLAW_MODEL=qclaw/pool-deepseek-v4-pro

# 目标群号（留空=所有群）
TARGET_GROUP_ID=

# 机器人昵称
BOT_NICKNAME=胖虎助手

# 数据目录（消息日志等）
DATA_DIR=./data
