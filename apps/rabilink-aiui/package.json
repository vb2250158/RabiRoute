{
  "name": "rabilink-aiui",
  "version": "0.1.2",
  "description": "RabiLink AIUI glasses-side continuous Agent stream and native LanguageModel configuration surface.",
  "main": "app.js",
  "type": "module",
  "private": true,
  "scripts": {
    "package:aix": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Package-RabiLinkAiui.ps1",
    "check": "node --check .\\scripts\\craft-browser-upload-helper.js && node --check .\\scripts\\craft-browser-embedded-aix-upload-helper.template.js && node --check .\\scripts\\Test-RabiLinkAiuiActiveIntelligenceE2E.mjs && node .\\scripts\\check-rabilink-aiui.mjs && node .\\scripts\\Audit-WebguiCoverage.mjs && node .\\scripts\\Audit-WebguiConfigSurface.mjs && node .\\scripts\\Audit-AiuiDesign.mjs && node .\\scripts\\Audit-RokidDeviceStatusBridge.mjs && node .\\scripts\\Smoke-RabiLinkApiContract.mjs && node .\\scripts\\Smoke-RabiLinkDeviceEnrollment.mjs && node .\\scripts\\Smoke-RabiLinkRelayMobileWebgui.mjs && node .\\scripts\\Smoke-RabiLinkRelayDeviceStatus.mjs && node .\\scripts\\Smoke-RabiLinkTranscriptPolicy.mjs && node .\\scripts\\Smoke-RabiLinkVoiceRuntime.mjs && node .\\scripts\\Smoke-RabiLinkAiuiRuntime.mjs && node .\\scripts\\Smoke-RabiLinkAiuiInkRuntime.mjs && node .\\scripts\\Smoke-RabiLinkAiuiInteractiveResize.mjs --mode transcription && node .\\scripts\\Smoke-RabiLinkAiuiInteractiveResize.mjs --mode configuration && node .\\scripts\\Smoke-RabiLinkAiuiStartupSafety.mjs && node .\\scripts\\Audit-RabiLinkAiuiAix.mjs && node .\\scripts\\Audit-RokidCraftUploadApi.mjs",
    "startup:safety": "node .\\scripts\\Smoke-RabiLinkAiuiStartupSafety.mjs",
    "startup:soak": "node .\\scripts\\Smoke-RabiLinkAiuiStartupSafety.mjs --soak",
    "interactive:resize": "node .\\scripts\\Smoke-RabiLinkAiuiInteractiveResize.mjs --mode transcription && node .\\scripts\\Smoke-RabiLinkAiuiInteractiveResize.mjs --mode configuration",
    "interactive:resize:daily": "node .\\scripts\\Smoke-RabiLinkAiuiInteractiveResize.mjs --ink-package @yodaos-pkg/ink-daily --mode transcription && node .\\scripts\\Smoke-RabiLinkAiuiInteractiveResize.mjs --ink-package @yodaos-pkg/ink-daily --mode configuration",
    "craft:headless": "node .\\scripts\\Smoke-RabiLinkAiuiCraftHeadless.mjs",
    "readiness": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Test-RabiLinkAiuiReadiness.ps1",
    "craft:staging": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Prepare-RabiLinkAiuiCraftUpload.ps1",
    "delivery": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Prepare-RabiLinkAiuiDelivery.ps1",
    "delivery:verify": "node .\\scripts\\Audit-RabiLinkAiuiAix.mjs --aix .\\dist\\rabilink-aiui.aix && node .\\scripts\\Smoke-RabiLinkAiuiInkRuntime.mjs --aix .\\dist\\rabilink-aiui.aix",
    "acceptance:local": "node .\\scripts\\Test-RabiLinkAiuiLocalAcceptance.mjs",
    "phone:inspect": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Inspect-RokidAiuiPhoneInstallSurface.ps1",
    "phone:inspect:deep": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Inspect-RokidAiuiPhoneInstallSurface.ps1 -PullApk -OpenAgentManage -ProbeAgentActivities -CaptureCurrentUi -TraceAgentStoreUi",
    "phone:inspect:store": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Inspect-RokidAiuiPhoneInstallSurface.ps1 -TraceAgentStoreUi",
    "phone:apk-inspect": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Inspect-RokidAiuiApkSurface.ps1",
    "push:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Push-RabiLinkAiuiToPhone.ps1",
    "craft:agents": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Invoke-RabiLinkAiuiCraftUpload.ps1 -ListAgents",
    "craft:upload:dryrun": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Invoke-RabiLinkAiuiCraftUpload.ps1",
    "craft:upload": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Invoke-RabiLinkAiuiCraftUpload.ps1 -Execute",
    "craft:open-browser-helper": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Open-RabiLinkAiuiCraftUploadHelper.ps1",
    "craft:open-embedded-helper": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Open-RabiLinkAiuiCraftEmbeddedUploadHelper.ps1",
    "craft:import-browser-report": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Import-RabiLinkAiuiBrowserCraftReport.ps1",
    "craft:watch-browser-report": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Wait-RabiLinkAiuiBrowserCraftReport.ps1",
    "craft:status": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Test-RabiLinkAiuiCraftStatus.ps1",
    "runtime:proof": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Test-RabiLinkAiuiRuntimeProof.ps1",
    "active-intelligence:e2e": "node .\\scripts\\Test-RabiLinkAiuiActiveIntelligenceE2E.mjs",
    "config-rollback:e2e": "node .\\scripts\\Test-RabiLinkAiuiActiveIntelligenceE2E.mjs --config-only",
    "device-status:e2e": "node .\\scripts\\Test-RabiLinkAiuiDeviceStatusE2E.mjs",
    "device-status:evidence": "node .\\scripts\\Collect-RabiLinkGlassesBatteryEvidence.mjs",
    "goal:evidence": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\Test-RabiLinkAiuiGoalEvidence.ps1"
  },
  "devDependencies": {
    "@yodaos-pkg/aix": "0.6.0",
    "@yodaos-pkg/ink": "^0.13.0",
    "@yodaos-pkg/ink-daily": "npm:@yodaos-pkg/ink@^0.14.0",
    "esbuild": "0.28.0",
    "playwright-core": "1.61.1"
  }
}
